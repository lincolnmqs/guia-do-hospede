DATABASE_URL="postgresql://guia:guia@localhost:5432/guia?schema=public"
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# MinIO / object storage para as imagens dos imóveis (S3-compatível).
# Opcional: sem estas variáveis a app continua funcionando com as URLs já
# persistidas no banco. Necessário apenas para (re)enviar imagens via script.
MINIO_ENDPOINT="https://minio.exemplo.com"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET="guia-do-hospede"
